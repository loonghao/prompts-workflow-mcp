{
  "name": "prompts-workflow-mcp",
  "version": "0.1.0",
  "description": "An intelligent MCP server that enables AI assistants to execute predefined workflows through natural language commands, supporting both global and project-specific automation templates.",
  "keywords": [
    "mcp",
    "workflow",
    "automation",
    "ai-assistant",
    "cli",
    "typescript"
  ],
  "author": "Prompts Workflow MCP Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loonghao/prompts-workflow-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/loonghao/prompts-workflow-mcp/issues"
  },
  "homepage": "https://github.com/loonghao/prompts-workflow-mcp#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "prompts-workflow-mcp": "./bin/prompts-workflow-mcp"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "schemas",
    "examples",
    "README.md",
    "README_zh.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm test",
    "release": "npm run validate && npm run build",
    "pre-publish": "node scripts/pre-publish-check.js"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fastmcp": "^2.2.2",
    "inquirer": "^9.2.0",
    "marked": "^12.0.0",
    "uuid": "^11.1.0",
    "yaml": "^2.8.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.3",
    "@semantic-release/npm": "^12.0.1",
    "@types/inquirer": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "semantic-release": "^24.2.5",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
