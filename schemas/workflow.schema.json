{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yourusername/prompts-workflow-mcp/schemas/workflow.schema.json",
  "title": "Workflow Definition",
  "description": "Schema for prompts-workflow-mcp workflow definitions",
  "type": "object",
  "required": ["name", "description", "version", "scope", "steps"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-zA-Z0-9_-]+$",
      "description": "Unique workflow identifier"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Human-readable description of the workflow"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., '1.0.0')"
    },
    "scope": {
      "type": "string",
      "enum": ["global", "project"],
      "description": "Workflow scope (global or project)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional tags for categorization"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/WorkflowStep"
      },
      "description": "Workflow execution steps"
    },
    "rollback": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/WorkflowStep"
      },
      "description": "Optional rollback steps for error recovery"
    },
    "timeout": {
      "type": "integer",
      "minimum": 0,
      "description": "Global timeout in milliseconds"
    },
    "retry": {
      "$ref": "#/definitions/RetryConfig",
      "description": "Retry configuration"
    },
    "environment": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Environment variables for the workflow"
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/WorkflowParameter"
      },
      "description": "Workflow parameters that can be passed at runtime"
    },
    "metadata": {
      "$ref": "#/definitions/WorkflowMetadata",
      "description": "Workflow metadata"
    }
  },
  "definitions": {
    "WorkflowStep": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Step identifier"
        },
        "type": {
          "type": "string",
          "enum": ["command", "action", "condition", "parallel", "sequential"],
          "description": "Step type"
        },
        "command": {
          "type": "string",
          "description": "Command to execute (for command type)"
        },
        "action": {
          "type": "string",
          "description": "Action identifier (for action type)"
        },
        "parameters": {
          "type": "object",
          "description": "Step-specific parameters"
        },
        "continue_on_error": {
          "type": "boolean",
          "description": "Whether to continue on error"
        },
        "timeout": {
          "type": "integer",
          "minimum": 0,
          "description": "Step timeout in milliseconds"
        },
        "condition": {
          "type": "string",
          "description": "Condition expression (for condition type)"
        },
        "working_directory": {
          "type": "string",
          "description": "Working directory for command execution"
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Environment variables for this step"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Step dependencies"
        },
        "retry": {
          "$ref": "#/definitions/RetryConfig",
          "description": "Step retry configuration"
        }
      }
    },
    "WorkflowParameter": {
      "type": "object",
      "required": ["name", "description", "type", "required"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Parameter name"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Parameter description"
        },
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "array", "object"],
          "description": "Parameter type"
        },
        "required": {
          "type": "boolean",
          "description": "Whether parameter is required"
        },
        "default": {
          "description": "Default value"
        },
        "enum": {
          "type": "array",
          "description": "Possible values (for enum-like parameters)"
        }
      }
    },
    "RetryConfig": {
      "type": "object",
      "required": ["max_attempts", "delay"],
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of retry attempts"
        },
        "delay": {
          "type": "integer",
          "minimum": 0,
          "description": "Delay between retries in milliseconds"
        },
        "backoff": {
          "type": "string",
          "enum": ["linear", "exponential"],
          "description": "Backoff strategy"
        },
        "max_delay": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum delay in milliseconds"
        },
        "retry_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Conditions that trigger retry"
        }
      }
    },
    "WorkflowMetadata": {
      "type": "object",
      "properties": {
        "author": {
          "type": "string",
          "description": "Author information"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        },
        "documentation": {
          "type": "string",
          "format": "uri",
          "description": "Workflow documentation URL"
        },
        "license": {
          "type": "string",
          "description": "License information"
        },
        "min_version": {
          "type": "string",
          "description": "Minimum required version of the system"
        },
        "category": {
          "type": "string",
          "description": "Workflow category"
        },
        "custom": {
          "type": "object",
          "description": "Custom metadata"
        }
      }
    }
  }
}
